# === Database ===
POSTGRES_DB=swiss_dna
POSTGRES_USER=sdp_admin
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# === Redis ===
REDIS_PASSWORD=changeme
REDIS_PORT=6379

# === MinIO (S3-compatible Storage) ===
MINIO_ROOT_USER=sdp_minio
MINIO_ROOT_PASSWORD=changeme123
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=sdp-documents

# === Backend ===
NODE_ENV=development
BACKEND_PORT=3000
JWT_SECRET=generate-a-secure-random-string-here
JWT_REFRESH_SECRET=generate-another-secure-random-string
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
ENCRYPTION_KEY=generate-32-byte-hex-key-for-aes256

# === Frontend ===
FRONTEND_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000

# === Mail (for verification emails) ===
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@swiss-dna.ch
SMTP_PASSWORD=changeme
SMTP_FROM=Swiss DNA Platform <noreply@swiss-dna.ch>

# === Swiss Compliance ===
# EDOEB = Eidgenoessischer Datenschutzbeauftragter
DATA_RETENTION_DAYS=365
DNA_RAW_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=3650
GUMG_COMPLIANCE_MODE=true
REVDSG_STRICT_MODE=true
